model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?  @unique
  password    String
  name        String
  role        Role     @default(USER)

  mojadId     MojadID?
  wallet      Wallet?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MojadID {
  id          String   @id @default(cuid())
  userId      String   @unique
  username    String   @unique
  reputation  Int      @default(0)
  trustScore  Int      @default(0)

  user        User     @relation(fields: [userId], references: [id])
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Float    @default(0)

  currency    String   @default("PI") // π only

  user        User     @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
  BUSINESS
  INVESTOR
}
model Company {
  id          String   @id @default(cuid())
  name        String
  description String?
  industry    String?
  website     String?

  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  jobs        Job[]

  createdAt   DateTime @default(now())
}model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  salary      Float?
  currency    String   @default("PI")

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  applications Application[]

  createdAt   DateTime @default(now())
}
model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String

  status    String   @default("pending")

  user      User     @relation(fields: [userId], references: [id])
  job       Job      @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  fromUserId  String?
  toUserId    String?
  amount      Float
  currency    String   @default("PI")

  type        String   // payment | escrow | reward | refund
  status      String   @default("pending")

  createdAt   DateTime @default(now())
}
model Escrow {
  id          String   @id @default(cuid())
  jobId       String?
  senderId    String
  receiverId  String?

  amount      Float
  currency    String   @default("PI")

  status      String   @default("held") // held | released | disputed

  createdAt   DateTime @default(now())
}
model PaymentLog {
  id          String   @id @default(cuid())
  transactionId String
  message     String

  createdAt   DateTime @default(now())
}
