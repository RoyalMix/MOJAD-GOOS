model SystemInsight {

  id          String   @id @default(cuid())

  key         String

  value       Json

  updatedAt   DateTime @updatedAt

}
model AITrainingData {

  id          String   @id @default(cuid())

  type        String   // match, moderation, ranking

  input       Json

  output      Json

  score       Float?

  createdAt   DateTime @default(now())

}
model UserActivityLog {

  id          String   @id @default(cuid())

  userId      String

  action      String

  metadata    Json?

  createdAt   DateTime @default(now())

}
model ModerationLog {

  id          String   @id @default(cuid())

  userId      String

  contentType String   // job, message, post, payment

  contentId   String?

  riskScore   Float    @default(0)

  status      String   // allowed | flagged | blocked

  reason      String?

  createdAt   DateTime @default(now())

}
model Verification {

  id          String   @id @default(cuid())

  userId      String

  type        String   // email | phone | KYC

  status      String   @default("pending")

  createdAt   DateTime @default(now())

  verifiedAt  DateTime?

}
model MojadUser {

  id          String   @id @default(cuid())

  mojadId     String   @unique

  email       String?  @unique

  phone       String?  @unique

  name        String?

  country     String?

  role        String   @default("user")

  verified    Boolean  @default(false)

  createdAt   DateTime @default(now())

}
model Escrow {

  id          String   @id @default(cuid())

  senderId    String

  receiverId  String

  amount      Float

  currency    String   @default("PI")

  status      String   @default("pending")

  createdAt   DateTime @default(now())

  releasedAt  DateTime?

}
model MeetingParticipant {

  id          String   @id @default(cuid())

  meetingId   String

  userId      String

  role        String

  joinedAt    DateTime?

}
model VideoMeeting {

  id            String   @id @default(cuid())

  hostId        String

  title         String

  description   String?

  meetingCode   String   @unique

  status        String   @default("scheduled")

  startedAt     DateTime?

  endedAt       DateTime?

  createdAt     DateTime @default(now())

}model VoiceCall {

  id          String   @id @default(cuid())

  callerId    String

  receiverId  String

  duration    Int?

  status      String

  createdAt   DateTime @default(now())

}model Message {
  id          String   @id @default(cuid())

  senderId    String
  receiverId  String

  type        String   @default("text")

  content     String?

  fileUrl     String?

  fileName    String?

  fileSize    Int?

  metadata    String?

  read        Boolean  @default(false)

  createdAt   DateTime @default(now())
}generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String   @unique
  fullName    String?
  country     String?
  createdAt   DateTime @default(now())

  mojadId     MojadID?
  wallet      Wallet?
  jobs        Job[]
  companies   Company[]
  referrals   Referral[]
  messages    Message[]
}

model MojadID {
  id            String   @id @default(cuid())
  userId        String   @unique
  trustScore    Int      @default(0)
  reputation    Int      @default(0)
  verified      Boolean  @default(false)

  user          User     @relation(fields: [userId], references: [id])
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  piBalance     Float    @default(0)

  user          User     @relation(fields: [userId], references: [id])
}

model Company {
  id            String   @id @default(cuid())
  name          String
  description   String?
  ownerId       String

  owner         User     @relation(fields: [ownerId], references: [id])
}

model Job {
  id            String   @id @default(cuid())
  title         String
  description   String?
  salaryPi      Float?

  userId        String
  owner         User     @relation(fields: [userId], references: [id])
}

model Opportunity {
  id            String   @id @default(cuid())
  title         String
  category      String
  description   String?
  createdAt     DateTime @default(now())
}

model Message {
  id            String   @id @default(cuid())
  content       String
  userId        String
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model Referral {
  id            String   @id @default(cuid())
  userId        String
  referralCode  String   @unique
  totalEarnedPi Float    @default(0)

  user          User     @relation(fields: [userId], references: [id])
}
model Wallet {
  id            String @id @default(cuid())

  userId        String @unique

  piBalance     Float @default(0)

  lockedPi      Float @default(0)

  totalEarnedPi Float @default(0)

  user          User @relation(fields:[userId], references:[id])

  transactions  PiTransaction[]
}

model PiTransaction {
  id          String @id @default(cuid())

  walletId    String

  amount      Float

  type        String

  status      String

  createdAt   DateTime @default(now())

  wallet      Wallet @relation(fields:[walletId], references:[id])
}
model Wallet {
  id            String @id @default(cuid())

  userId        String @unique

  piBalance     Float @default(0)

  lockedPi      Float @default(0)

  totalEarnedPi Float @default(0)

  user          User @relation(fields:[userId], references:[id])

  transactions  PiTransaction[]
}
model Referral {
  id            String   @id @default(cuid())

  referrerId    String
  referredId    String?

  code          String   @unique

  reward        Float    @default(0)

  status        String   @default("pending")

  createdAt     DateTime @default(now())
}
model Stream {
  id          String   @id @default(cuid())

  creatorId   String

  title       String

  views       Int      @default(0)

  outcomes    Int      @default(0)

  reward      Float    @default(0)

  createdAt   DateTime @default(now())
}
model MojadID {
  id                String   @id @default(cuid())

  userId            String   @unique

  username          String   @unique

  verificationLevel String   @default("basic")

  trustScore        Int      @default(50)

  reputationScore   Int      @default(0)

  country           String?

  createdAt         DateTime @default(now())
}
model Verification {
  id          String   @id @default(cuid())

  userId      String

  badgeType   String

  verified    Boolean  @default(false)

  createdAt   DateTime @default(now())
}
model User {
  id              String   @id @default(cuid())

  email           String   @unique

  password        String

  fullName        String?

  username        String?  @unique

  country         String?

  phone           String?

  avatar          String?

  trustScore      Int      @default(50)

  reputationScore Int      @default(0)

  createdAt       DateTime @default(now())
}
model Notification {
  id          String   @id @default(cuid())

  userId      String

  title       String

  message     String

  type        String

  read        Boolean  @default(false)

  createdAt   DateTime @default(now())
}
model Message {
  id          String   @id @default(cuid())

  senderId    String

  receiverId  String

  content     String

  type        String   @default("text")

  read        Boolean  @default(false)

  createdAt   DateTime @default(now())
}
model Conversation {
  id          String   @id @default(cuid())

  participantA String

  participantB String

  createdAt   DateTime @default(now())
}
datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}
model FeedPost {

  id          String   @id @default(cuid())

  authorId    String

  type        String

  title       String

  content     String

  mediaUrl    String?

  views       Int      @default(0)

  likes       Int      @default(0)

  shares      Int      @default(0)

  createdAt   DateTime @default(now())

}
model FeedInteraction {

  id          String   @id @default(cuid())

  userId      String

  postId      String

  action      String

  createdAt   DateTime @default(now())

}
model SponsoredPost {

  id          String   @id @default(cuid())

  postId      String

  ownerId     String

  budgetPi    Float

  status      String

  createdAt   DateTime @default(now())

}
model Subscription {

  id          String   @id @default(cuid())

  userId      String

  plan        String

  active      Boolean  @default(true)

  createdAt   DateTime @default(now())

}
model Notification {

  id          String   @id @default(cuid())

  userId      String

  type        String

  title       String

  message     String

  read        Boolean  @default(false)

  createdAt   DateTime @default(now())

}
model SearchHistory {

  id        String   @id @default(cuid())

  userId    String

  query     String

  type      String

  createdAt DateTime @default(now())

}
model TrustProfile {

  id          String   @id @default(cuid())

  userId      String   @unique

  score       Float    @default(50)

  level       String   @default("new")

  verified    Boolean  @default(false)

  updatedAt   DateTime @updatedAt
}
