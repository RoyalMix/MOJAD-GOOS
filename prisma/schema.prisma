generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String   @unique
  fullName    String?
  country     String?
  createdAt   DateTime @default(now())

  mojadId     MojadID?
  wallet      Wallet?
  jobs        Job[]
  companies   Company[]
  referrals   Referral[]
  messages    Message[]
}

model MojadID {
  id            String   @id @default(cuid())
  userId        String   @unique
  trustScore    Int      @default(0)
  reputation    Int      @default(0)
  verified      Boolean  @default(false)

  user          User     @relation(fields: [userId], references: [id])
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  piBalance     Float    @default(0)

  user          User     @relation(fields: [userId], references: [id])
}

model Company {
  id            String   @id @default(cuid())
  name          String
  description   String?
  ownerId       String

  owner         User     @relation(fields: [ownerId], references: [id])
}

model Job {
  id            String   @id @default(cuid())
  title         String
  description   String?
  salaryPi      Float?

  userId        String
  owner         User     @relation(fields: [userId], references: [id])
}

model Opportunity {
  id            String   @id @default(cuid())
  title         String
  category      String
  description   String?
  createdAt     DateTime @default(now())
}

model Message {
  id            String   @id @default(cuid())
  content       String
  userId        String
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model Referral {
  id            String   @id @default(cuid())
  userId        String
  referralCode  String   @unique
  totalEarnedPi Float    @default(0)

  user          User     @relation(fields: [userId], references: [id])
}
model Wallet {
  id            String @id @default(cuid())

  userId        String @unique

  piBalance     Float @default(0)

  lockedPi      Float @default(0)

  totalEarnedPi Float @default(0)

  user          User @relation(fields:[userId], references:[id])

  transactions  PiTransaction[]
}

model PiTransaction {
  id          String @id @default(cuid())

  walletId    String

  amount      Float

  type        String

  status      String

  createdAt   DateTime @default(now())

  wallet      Wallet @relation(fields:[walletId], references:[id])
}
